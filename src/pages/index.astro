<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>kimjlak.com</title>

    <meta property="og:title" content="jlk" />
<meta property="og:description" content="kimjlak.com" />
<meta property="og:image" content="/og.jpg" />
<meta property="og:type" content="website" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content="/og.jpg" />
  </head>

  <body style="margin:0; font-family: system-ui; background:#0b0b0f; color:white;">

    <!-- Top Nav -->
    <nav style="display:flex; justify-content:center; gap:28px; padding:22px 0; font-size:14px; letter-spacing:0.5px;">
      <a href="/" style="color:white; text-decoration:none; opacity:0.9;">Home</a>
      <a href="/contact" style="color:white; text-decoration:none; opacity:0.5;">Contact</a>
    </nav>

    <!-- MAIN WRAPPER -->
    <main style="max-width:900px; margin:auto; padding:60px 22px 80px;">

      <!-- NAME -->
      <header style="margin-bottom:60px;">
        <h1 style="font-size:clamp(30px, 6.5vw, 44px); margin:0; font-weight:500;">
          joshua lak kim
        </h1>
      </header>

      <!-- PROJECTS -->
      <section style="max-width:650px; margin-left:0;">

        <h2 style="font-size:12px; letter-spacing:1px; opacity:0.6; margin-bottom:22px;">
          Projects
        </h2>

        <div style="
          display:flex;
          flex-direction:column;
          gap:60px;
          font-size:clamp(15px, 4.2vw, 18px);
          line-height:1.6;
        ">

          <!-- Project: Entanglement -->
          <div style="text-align:left;">

            <img
              src="/entanglement.jpeg"
              style="
                width:100%;
                max-width:240px;
                height:auto;
                display:block;
                margin-bottom:14px;
              "
            />

            <strong>Entanglement</strong><br/>
            <span style="opacity:0.7;">a graphic novel, 2025</span><br/>
            written by Joshua Lak Kim &amp; Ciara Ni Chuirc<br/>
            <span style="opacity:0.7;">art by Max Von Fafner</span><br/>
            <span style="opacity:0.7;">AWA Studios / Futurific Studios</span>

          </div>

          <br/><br/>

          <!-- Project: Game On -->
          <div style="text-align:left;">

            <img
              src="/gameon.jpg"
              style="
                width:100%;
                max-width:240px;
                height:auto;
                display:block;
                margin-bottom:14px;
              "
            />

            <strong>Game On</strong><br/>
            <span style="opacity:0.7;">a short film, 2015</span><br/>
            <span style="font-style:italic; opacity:0.8;">actor - Charlie Goodfellow</span><br/>
            <span style="opacity:0.7;">written & directed by Jennifer Crystle</span>

          </div>

        </div>

      </section>

    </main>

  </body>
</html>